#!/usr/bin/env bash
# skyview-switch {v2|v1|status}
#
# Flip the active display server between SkyView 2 (primary) and the v1 baseline
# (rollback) WITHOUT reflashing or pulling the card. They are mutually exclusive —
# both serve :3000 and only one runs at a time, so there is NO runtime performance
# cost: the inactive version is just dormant files on disk. The shared dump1090
# decoder on :8080 is never touched, so traffic keeps flowing across a switch.
#
#   skyview-switch v1       roll back to the v1 baseline (skylight-server)
#   skyview-switch v2       return to SkyView 2 (skyview)
#   skyview-switch status   show which is active + health
#
# Health-checked: if the target doesn't come up on :3000, it reverts automatically.
# Run over SSH for a remote rollback:  ssh pi@skyview.local skyview-switch v1
set -uo pipefail

V2_SVC=skyview
V1_SVC=skylight-server
STATE=/var/lib/skyview
ACTIVE_FILE="$STATE/active"
sudo mkdir -p "$STATE" 2>/dev/null || true

have() { systemctl list-unit-files 2>/dev/null | grep -q "^$1\.service"; }
health() { for _ in $(seq 1 20); do curl -fsS http://localhost:3000/api/health >/dev/null 2>&1 && return 0; sleep 1; done; return 1; }
# v1's health path differs from v2's; accept either so the check works both ways.
health_any() { for _ in $(seq 1 20); do curl -fsS http://localhost:3000/api/health >/dev/null 2>&1 && return 0; curl -fsS http://localhost:3000/ >/dev/null 2>&1 && return 0; sleep 1; done; return 1; }
reload_kiosk() { pkill -f "/usr/lib/chrom[i]um" 2>/dev/null || true; }   # supervisor relaunches it

status() {
  echo "active marker : $(cat "$ACTIVE_FILE" 2>/dev/null || echo unknown)"
  echo "$V2_SVC : $(systemctl is-active $V2_SVC 2>/dev/null)   (SkyView 2)"
  if have "$V1_SVC"; then echo "$V1_SVC : $(systemctl is-active $V1_SVC 2>/dev/null)   (v1 baseline)"; else echo "$V1_SVC : not installed"; fi
  echo -n "display :3000 : "; curl -fsS http://localhost:3000/api/health >/dev/null 2>&1 && echo "healthy" || echo "DOWN"
}

switch_to() { # $1=target service  $2=other service  $3=label
  local target="$1" other="$2" label="$3"
  have "$target" || { echo "Cannot switch: $target is not installed."; exit 1; }
  echo "==> switching to $label ($target)"
  sudo systemctl disable --now "$other" 2>/dev/null || true
  sudo systemctl enable --now "$target"
  if health_any; then
    printf '%s' "$label" | sudo tee "$ACTIVE_FILE" >/dev/null
    reload_kiosk
    echo "OK — $label is live on :3000 (decoder untouched)."
  else
    echo "!! $label did not come up — reverting to $other"
    sudo systemctl disable --now "$target" 2>/dev/null || true
    sudo systemctl enable --now "$other" 2>/dev/null || true
    reload_kiosk
    exit 1
  fi
}

case "${1:-status}" in
  v1) switch_to "$V1_SVC" "$V2_SVC" v1 ;;
  v2) switch_to "$V2_SVC" "$V1_SVC" v2 ;;
  status) status ;;
  *) echo "usage: skyview-switch {v1|v2|status}"; exit 2 ;;
esac
